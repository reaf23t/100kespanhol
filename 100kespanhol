            const restartBtn = document.getElementById('restart-btn');
            
            answersDiv.innerHTML = '';
            
            for (let i = 1; i <= totalQuestions; i++) {
                const selectedOption = document.querySelector(`input[name="q${i}"]:checked`);
                const correctAnswer = answers[`q${i}`];
                const questionDiv = document.querySelector(`input[name="q${i}"]`).closest('.question');
                const correctAnswerDiv = questionDiv.querySelector('.correct-answer');
                const explanationDiv = questionDiv.querySelector('.explanation');
                
                // Mostrar todas as respostas corretas e explicações
                correctAnswerDiv.style.display = 'block';
                explanationDiv.style.display = 'block';
                
                if (selectedOption && selectedOption.value === correctAnswer) {
                    score++;
                    correctAnswerDiv.className = 'correct';
                } else {
                    correctAnswerDiv.className = 'incorrect';
                }
            }
            
            const percentage = (score / totalQuestions) * 100;
            scoreDiv.textContent = `Você acertou ${score} de ${totalQuestions} questões (${percentage.toFixed(1)}%)`;
            
            if (percentage >= 70) {
                scoreDiv.style.color = '#28a745';
            } else if (percentage >= 50) {
                scoreDiv.style.color = '#ffc107';
            } else {
                scoreDiv.style.color = '#dc3545';
            }
            
            resultDiv.style.display = 'block';
            submitBtn.style.display = 'none';
            restartBtn.style.display = 'block';
            
            // Scroll to results
            resultDiv.scrollIntoView({ behavior: 'smooth' });
        });
        
        document.getElementById('restart-btn').addEventListener('click', function() {
            // Reset all selections
            const allInputs = document.querySelectorAll('input[type="radio"]');
            allInputs.forEach(input => {
                input.checked = false;
            });
            
            // Hide all correct answers and explanations
            const allAnswerDivs = document.querySelectorAll('.correct-answer');
            allAnswerDivs.forEach(div => {
                div.style.display = 'none';
                div.classList.remove('correct', 'incorrect');
            });
            
            const allExplanationDivs = document.querySelectorAll('.explanation');
            allExplanationDivs.forEach(div => {
                div.style.display = 'none';
            });

            // Reset buttons and result
            document.getElementById('submit-btn').style.display = 'block';
            document.getElementById('restart-btn').style.display = 'none';
            document.getElementById('result').style.display = 'none';
            
            // Scroll to top
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    </script>
</body>
</html>
